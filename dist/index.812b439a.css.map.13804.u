{"mappings":"AACA;;;;;;;;;;;;;;AAcA;;;;;AAKA;;;;;;;;;;AASA;;;;;;;;;;;AAWA;;;;;;;;AAQA;;;;;;;AAOA;;;;;;AAMA;;;;;;;;;AASA;;;;;;AAMA;;;;;;;;;AAWA;;;;;AAMA;;;;;;;;;;;AAWA;;;;AAIA;EAEE;;;;EAIA;;;;;;;;;;;;;EAaA;;;;;;;;;;;;;;EAcA;;;;EAIA;;;;;;;;;;EAUA;;;;EAIA;;;;;;;;;EASA;;;;;EAKA;;;;;AAMF;EAEE;;;;;;EAMA;;;;EAIA;;;;EAIA;;;;;;EAMA;;;;;;EAMA;;;;EAIA;;;;;;;;EAQA;;;;;;EAMA;;;;;AAMF;;;;;ACtOA;;;;;;;;;;;;AAYA;;;;AAQA;;;;AAIA;;;;;;;;;;;;AAYA;;;;;;;;;;;;AAYA;;;;;;;AAOA;;;;;;;;AAQA;;;;;;AAMA;;;;;;AAMA;;;;;;AAUA;;;;;;;AAOA;;;;;;;;;;;AAWA;;;;AAIA;;;;;;AAMA;EAEE;;;;;;EAMA;;;;;;;;;;;;EAYA;;;;;EAKA;;;;;;;;;;;;EAYA;;;;EAQA;;;;EAIA;;;;EAIA;;;;;;;ACtKF;;;;AAIA;;;;;;;;;AASA;;;;;;;AAOA;;;;;;;;AAQA;;;;;;;;;AASA;;;;;;;;;;;;;;AAeA;;;;;;;AAOA;;;;;;AAMA;;;;AAIA;;;;;AAKA;;;;;;;AAOA;;;;;;;;;;;;;;AAcA;;;;;AAKA;;;;;;;AAOA;;;;;;AAMA;;;;;AAKA;;;;;;AAMA;;;;;;;;;;;;;;AAgBA;;;;;;;AAOA;;;;;AAKA;;;;;;;;AAQA;;;;;;AAMA;;;;;;;AAOA;;;;;;AAMA;;;;;;;;;AASA;;;;;;;AAOA;;;;;;AAMA;;;;;;;AAOA;;;;;;AAMA;;;;;AAKA;;;;;AAKA;;;;;AAKA;;;;;;;AAOA;;;;;;;;;;AAUA;;;;;;;;;;;;;;AAcA;;;;AAIA;EAEE;;;;EAIA;;;;EAKF;;;;;AAQA;EAEE;;;;EAIA;;;;EAIA;;;;;AAKF;EACE;;;;EAIA;;;;EAIA;;;;EAIA;;;;;AAOF;EACE;;;;;AAKF;EACE;;;;EAIA;;;;EAIA;;;;EAIA;;;;;EAKA;;;;;EAKA;;;;EAIA;;;;EAIA;;;;;EAKA;;;;EAIA;;;;;EAKA;;;;;;;EAOA;;;;;;;;EAQA;;;;EAIA;;;;EAIA;;;;;;EAMA;;;;;;EAMA;;;;;EAKA;;;;;AAKF;EACE;;;;;EAGK;;;;;;AClaP;;;;;;;;;;;;;AAaA;;;;;;;;;AASA;;;;AAQA;;;;AAIA;;;;;;;;AAQA;;;;;;;;;AASA;;;;;;;AAOA;;;;;;;;AAQA;;;;;;;;AAQA;;;;AAIA;;;;;;;;AAQA;;;;;;;;;;;;AAYA;;;;AAIA;EAEE;;;;;;EAMA;;;;;EAKA;;;;;EAKA;;;;;EAKA;;;;EAIA;;;;EAIA;;;;;;EAMA;;;;;;AAMF;;;;AAQA;;;;;ACtJA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiHA;;;;;AAQA;;;;AAaA;;;;;;;;;;AAeA;;;;;AASA;;;;;;AAQA;;;;AAMA;;;;;AAYA;;;;;AAOA;;;;AAUA;;;;;;;AAYA;;;;AAMA;;;;;;;AAOA;;;;AAGA;;;;AAQA;;;;;;AAUA;;;;;;;;;;;;;AAmBA;;;;AAQA;;;;;;AAWA;;;;AAMA;;;;AAMA;;;;AAMA;;;;AAAA;;;;AAQA;;;;;AAOA;;;;AAOA;;;;;AAOA;;;;AAMA;;;;AAeA;;;;;AAIA;;;;AAGA;;;;;;AAUA;;;;AAMA;;;;AAOA;;;;;AAQA;;;;AAOA;;;;AAQA;;;;;AAcA;;;;;AAMA;;;;AAGA;;;;AAGA;;;;AAGA;;;;;AAIA;;;;AAGA;;;;;;;;;;;;AAWA","sources":["src/header/header.css","src/home/home.css","src/fitness/fitnes.css","src/weightlifting/weightlifting.css","src/input.css"],"sourcesContent":["\r\n.nav-img {\r\n  display: flex;\r\n  position: absolute;\r\n  width: 90px;\r\n  height: 90px;\r\n  border: .2rem solid;\r\n  border-color: rgb(245 158 11 / var(--tw-border-opacity, 1));\r\n  border-radius: 50%;\r\n  margin-top: .75rem;\r\n  margin-left: 1.25rem;\r\n  z-index: 1; \r\n  transition: .8s;\r\n}\r\n\r\n.nav-img:hover {\r\n  transform: scale(1.15);\r\n  animation: spin 1s linear 1; \r\n}\r\n\r\n@keyframes spin {\r\nfrom {\r\n  transform: rotate(0);\r\n}\r\nto {\r\n    transform: rotateY(360deg);\r\n  }\r\n}\r\n\r\n.header {\r\n  display: flex;\r\n  top: 0;\r\n  left: 0;\r\n  max-width: var(--max-width);\r\n  margin: 0 auto;\r\n  padding: .5rem 1rem;\r\n  background-color: var(--black);\r\n  z-index: 10;\r\n}\r\n\r\n.nav-logo {\r\n  width: 600px !important;\r\n  text-align: center;\r\n  font-size: var(--medium-fz);\r\n  color: var(--main-color);\r\n  margin-left: 3rem;\r\n}\r\n\r\n.logo-name {\r\n  font-weight: 700;\r\n  font-size: 2.5rem;\r\n  padding-top: 1rem;\r\n  z-index: 10;\r\n}\r\n \r\nnav a {\r\n  display: flex;\r\n  flex-direction: column;\r\n  z-index: 10;\r\n}\r\n\r\n.nav {\r\n  width: 100%;\r\n  position: relative;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: .5rem 2.5%;\r\n}\r\n\r\n.nav-menu {\r\n  display: flex;\r\n  gap: .6rem;\r\n  z-index: 10;\r\n}\r\n\r\n.nav-close, \r\n.nav-toggle {\r\n  display: flex;\r\n  align-items: center;\r\n  position: absolute;\r\n  font-size: 2.5rem;\r\n  color: var(--text-color);\r\n  cursor: pointer;\r\n  display: none;\r\n}\r\n\r\n.nav-menu .nav-link {\r\n  /* font-size: 14px !important; */\r\n  position: relative;\r\n  color: var(--text-color);\r\n}\r\n\r\n.nav-menu .nav-link::after {\r\n  content: '';\r\n  position: absolute;\r\n  left: 0;\r\n  bottom: -0.3rem;\r\n  width: 0;\r\n  height: 2px;\r\n  background-color: var(--main-color);\r\n  transition: all .3s;\r\n}\r\n\r\n.nav-menu .nav-link:hover::after {\r\n  width: 100%;\r\n}\r\n\r\n@media screen and (max-width: 897px) {\r\n\r\n  .wrapper {\r\n    width: 84.25rem;\r\n  }\r\n\r\n  .nav-menu {\r\n    position: fixed;\r\n    top: -100%;\r\n    left: 0;\r\n    width: 100%;\r\n    background-color: #111;\r\n    padding: .5rem .5rem;\r\n    box-shadow: var(--box-shadow);\r\n    text-align: center;\r\n    display: flex;\r\n    flex-direction: column;\r\n  }\r\n \r\n  .nav-close {\r\n    position: absolute;\r\n    top: 1.5rem;\r\n    right: 8rem;\r\n    width: 2.5rem;\r\n    height: 2.5rem;\r\n    border-radius: 50%;\r\n    box-shadow: var(--box-shadow);\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    z-index: 10;\r\n  }\r\n\r\n  .nav-close:hover {\r\n    transform: rotate(90deg);\r\n  }\r\n\r\n  .nav-toggle {\r\n    width: 2.5rem;\r\n    height: 2.5rem;\r\n    right: 7rem;\r\n    box-shadow: var(--box-shadow);\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n  }\r\n\r\n  .nav-img {\r\n    z-index: 9;\r\n  }\r\n\r\n  .nav-logo {\r\n    display: flex;\r\n    width: 680px !important;\r\n    text-align: center;\r\n    font-size: var(--medium-fz);\r\n    color: var(--main-color);\r\n    margin-left: 18rem;\r\n  }\r\n\r\n  .show-menu ul li {\r\n    max-width: fit-content;\r\n    margin-right: 2rem;\r\n  }\r\n\r\n  .nav-menu .nav-link:hover::after {\r\n    width: 20rem;\r\n  }\r\n\r\n}\r\n\r\n@media screen and (max-width: 420px) {\r\n\r\n  .header {\r\n    max-width: 44rem !important;\r\n    margin: 0;\r\n    padding: 0;\r\n  }\r\n\r\n  .wrapper {\r\n    max-width: 44rem !important;\r\n  }\r\n\r\n  .nav {\r\n    max-width: 44rem;\r\n  }\r\n\r\n  .nav-logo {\r\n    font-size: 1.5rem !important;\r\n    line-height: 1.25rem !important;\r\n    margin-left: 0;\r\n  }\r\n\r\n  .nav-toggle {\r\n    margin-top: -2rem;\r\n    margin-right: -4rem;\r\n    z-index: 10;\r\n  }\r\n\r\n  .nav-close {\r\n    right: 4rem;\r\n  }\r\n\r\n  .nav-img {\r\n    width: 60px;\r\n    height: 60px;\r\n    margin-top: 1rem;\r\n    margin-left: 2rem;\r\n    z-index: 9;\r\n  }\r\n\r\n  .logo-name {\r\n    font-weight: 500;\r\n    font-size: 2rem;\r\n    line-height: 1.5rem;\r\n  }\r\n\r\n  .show-menu {\r\n    max-width: 44rem;\r\n  }\r\n\r\n}\r\n\r\n.show-menu {\r\n  top: 0;\r\n  z-index: 8;\r\n}","\r\n.home-section {\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  flex-wrap: wrap;\r\n  gap: 2rem;\r\n  padding-top: 2rem 3rem;\r\n  max-width: var(--max-width);\r\n  margin: 0 auto;\r\n  background-color: rgba(4, 14, 152, 0.947);\r\n}\r\n\r\n.home-section .home-content {\r\n  flex: 1 1 40rem;\r\n}\r\n\r\n.home-content .home-img {\r\n  flex: 1 1 40rem;\r\n}\r\n\r\n.home-content {\r\n  margin-left: 3rem;\r\n}\r\n\r\n.home-section::before {\r\n  content: \"FITNESS\";\r\n  position: absolute;\r\n  top: 3rem;\r\n  right: 10rem;\r\n  line-height: 7rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n  opacity: 0.05;\r\n  font-size: 18rem;\r\n}\r\n\r\n.home-content::before {\r\n  content: \"WEIGHTLIFTING\";\r\n  position: absolute;\r\n  top: 15rem;\r\n  right: 2rem;\r\n  line-height: 7rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n  opacity: 0.05;\r\n  font-size: 10rem;\r\n}\r\n\r\n.home-content h4 {\r\n  margin-bottom: 1rem; \r\n  font-size: 2.5rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n}\r\n\r\n.home-content h2 {\r\n  margin-bottom: 1rem;\r\n  font-size: var(--big-fz);\r\n  font-weight: 800;\r\n  line-height: 6rem;\r\n  color: var(--text-color);\r\n}\r\n\r\n.home-content h2 span {\r\n  -webkit-text-fill-color: var(--black);\r\n  -webkit-text-stroke: 4px var(--main-color);\r\n  font-size: 5.5rem;\r\n}\r\n\r\n.home-content p {\r\n  margin-bottom: 2rem;\r\n  color: var(--text-color);\r\n  font-size: 1.6rem;\r\n}\r\n\r\n.club-name {\r\n  font-weight: 700;\r\n  font-size: 2rem;\r\n  color: var(--main-color);\r\n}\r\n\r\nspan.club-name:hover {\r\n  font-size: 3rem; \r\n}\r\n\r\n.home-img {\r\n  width: 500px;\r\n  height: 650px;\r\n  margin-right: 2.5rem;\r\n  z-index: 1;\r\n}\r\n\r\n.btn {\r\n  display: inline-block;\r\n  padding: 1rem 2rem;\r\n  font-size: 2rem;\r\n  font-weight: 700;\r\n  color: var(--black);\r\n  background-color: var(--main-color);\r\n  border-radius: .5rem;\r\n  cursor: pointer;\r\n}\r\n\r\n.btn:hover {\r\n  box-shadow: 0 .3rem 1rem var(--main-color);\r\n}\r\n\r\n.bg-blur {\r\n  position: absolute;\r\n  box-shadow: 0 0 100rem 8rem var(--main-color);\r\n  z-index: -1;\r\n}\r\n\r\n@media screen and (max-width: 420px) {\r\n\r\n  .home-section {\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n  }\r\n\r\n  .home-section::before {\r\n    content: 'FITNESS';\r\n    position: absolute;\r\n    top: 54%;\r\n    right: 6rem;\r\n    line-height: 7rem;\r\n    font-weight: 800;\r\n    color: var(--text-color);\r\n    opacity: 0.05;\r\n    font-size: 9rem;\r\n  }\r\n\r\n  .home-content {\r\n    margin-left: 2.5rem;\r\n    margin-right: 2.5rem;\r\n  }\r\n\r\n  .home-content::before {\r\n    content: \"WEIGHTLIFTING\";\r\n    position: absolute;\r\n    top: 66%;\r\n    right: 3rem;\r\n    line-height: 7rem;\r\n    font-weight: 800;\r\n    color: var(--text-color);\r\n    opacity: 0.05;\r\n    font-size: 5rem;\r\n  }\r\n\r\n  .home-content h4 {\r\n    font-size: 2.5rem;\r\n  }\r\n\r\n  .home-content h2 {\r\n    font-size: 2.5rem;\r\n  }\r\n\r\n  .home-content h2 span {\r\n    font-size: 5.5rem;\r\n  }\r\n\r\n  .btn {\r\n    width: 20rem;\r\n  }\r\n\r\n  .home-img {\r\n    margin-top: -5rem;\r\n    width: 444px;\r\n    height: 544px;\r\n  }\r\n} ","\r\n.programms {\r\n  background-color: rgba(4, 14, 152, 0.947);\r\n}\r\n\r\n.heading {\r\n  padding-top: 2rem;\r\n  font-size: var(--big-fz);\r\n  margin-bottom: 1rem;\r\n  font-weight: 800;\r\n  text-align: center;\r\n  color: var(--main-color);\r\n}\r\n\r\n.sub-heading {\r\n  max-width: 60rem;\r\n  margin: 0 auto;\r\n  text-align: center;\r\n  color: var(--text-color);\r\n}\r\n\r\n.programms .box-container {\r\n  margin-top: 4rem;\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  justify-content: center;\r\n  gap: 2rem;\r\n}\r\n\r\n.programms .box-container .programm-box {\r\n  padding: 1rem;\r\n  background-color: var(--ligth-black);\r\n  border: .1rem solid var(--main-color);\r\n  border-radius: 1rem;\r\n  box-shadow: var(--box-shadow);\r\n  transition: all .5s;\r\n}\r\n\r\n.programms .box-container .programm-box span {\r\n  display: inline-block;\r\n  width: 4rem;\r\n  height: 4rem;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  margin-bottom: 1rem;\r\n  font-size: var(--small-fz);\r\n  color: var(--text-color);\r\n  border-radius: 0.5rem;\r\n  background-color: var(--main-color);\r\n  box-shadow: var(--box-shadow);\r\n}\r\n\r\n.programms .box-container .programm-box h4 {\r\n  margin-bottom: 0.5rem;\r\n  font-size: 2.5rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n}\r\n\r\n.programms .box-container .programm-box p {\r\n  margin-bottom: 2rem;\r\n  font-size: 1.5rem;\r\n  color: var(--text-color);\r\n}\r\n\r\n.programms .box-container .programm-box a:hover {\r\n  letter-spacing: .3rem;\r\n}\r\n\r\n.services .services-img {\r\n  margin-top: 2rem;\r\n  position: relative; \r\n}\r\n\r\n.services .services-img img {\r\n  margin: 0 auto;\r\n  border-radius: 1rem;\r\n  box-shadow:var(--box-shadow);\r\n  max-width: 78rem;\r\n}\r\n\r\n.services-img .box-container {\r\n  position: relative;\r\n  bottom: -2rem;\r\n  width: calc(100% - 4rem);\r\n  padding: 2rem;\r\n  margin: 0 2rem;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 2rem;\r\n  background-color: var(--black);\r\n  border-radius: 1rem;\r\n  box-shadow:var(--box-shadow);\r\n}\r\n\r\n.services-img .box-container .service-box img {\r\n  width: 5rem;\r\n  box-shadow: none;\r\n}\r\n\r\n.services-img .box-container .service-box {\r\n  flex: 1 1 25rem;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 1rem;\r\n}\r\n\r\n.services-img .box-container .service-box .box-content h4 {\r\n  font-size: 1.5rem;\r\n  color: var(--text-color);\r\n  margin-bottom: 0.5rem;\r\n}\r\n\r\n.service-box .box-content p {\r\n  font-size: 1.3rem;\r\n  color: var(--text-color);\r\n}\r\n\r\nhr {\r\n  margin: 2rem 9rem  !important;\r\n  border-top-color: rgba(233, 233, 241, 0.069) !important;\r\n  border-top-width: 2px !important;\r\n}\r\n\r\nsection ul li {\r\n  font-size: var(--big-fz);\r\n  color: var(--main-color);\r\n  margin-left: 2rem;\r\n  border: 3px solid  rgba(4, 14, 152, 0.947);\r\n  border-radius: 1rem;\r\n  padding: .5rem;\r\n  height: fit-content;\r\n  background: linear-gradient(135deg, rgba(255, 255, 255, .1), rgba(255, 255, 255, 0));\r\n  backdrop-filter: blur(5px);\r\n  -webkit-backdrop-filter: blur(5px);\r\n  border:  2px solid rgba(233, 233, 241, 0.069);\r\n  box-shadow: 0 8px 32px 0 rgba (0, 0, 0, .8);\r\n  text-align: center;\r\n}\r\n\r\nul.strong {\r\n  display: flex;\r\n  margin-top: 2rem;\r\n  margin-right: 1rem;\r\n  line-height: 2.5rem;\r\n}\r\n\r\nul.strong img {\r\n  max-width: 30rem;\r\n  margin-right: 2rem;\r\n}\r\n\r\nul.fit {\r\n  display: flex;\r\n  max-width: 80rem;\r\n  margin-top: 2rem;\r\n  line-height: 2.5rem;\r\n  margin-right: 1rem;\r\n}\r\n\r\nul.fit img {\r\n  margin-top: -15rem;\r\n  max-width: 34rem;\r\n  margin-left: 2rem;\r\n}\r\n\r\nul.build {\r\n  display: flex;\r\n  max-width: 80rem;\r\n  margin-top: 2rem;\r\n  line-height: 2.5rem;\r\n}\r\n\r\nul.build img {\r\n  max-height: 26rem;\r\n  margin-left: -20rem;\r\n  margin-top: 6rem;\r\n}\r\n\r\nul.grow {\r\n  flex-direction: row-reverse;\r\n  max-width: 80rem;\r\n  margin-top: -5rem;\r\n  margin-right: 1rem;\r\n  line-height: 2.5rem;\r\n  display: flex;\r\n}\r\n\r\nul.grow img.grow {\r\n  max-width: 26rem;\r\n  margin-top: -28rem;\r\n  margin-right: 28rem;\r\n  position: absolute;\r\n}\r\n\r\nul.grow img.lower {\r\n  max-height: 25rem;\r\n  margin-top: -27rem;\r\n  margin-right: -34rem;\r\n}\r\n\r\nul.upperFit {\r\n  display: flex;\r\n  margin-top: 1rem;\r\n  line-height: 2.5rem;\r\n  margin-right: 32rem;\r\n}\r\n\r\nul.upperFit img.man {\r\n  max-height: 27rem;\r\n  margin-top: 7rem;\r\n  position: absolute;\r\n}\r\n\r\nul.upperFit img.girl {\r\n  margin-top: 1rem;\r\n  max-height: 18rem;\r\n}\r\n\r\nul.flexBody {\r\n  display: flex;\r\n  line-height: 2.5rem;\r\n}\r\n\r\nul.flexBody li {\r\n  margin-top: 23rem;\r\n  margin-left: 52rem;\r\n}\r\n\r\nul.flexBody img {\r\n  max-width: 38rem;\r\n  margin-top: -2rem;\r\n  margin-left: 36rem;\r\n  position: absolute;\r\n}\r\n\r\n.fitness-container {\r\n  margin-top: 2rem;\r\n  border-radius: 1rem;\r\n  box-shadow:var(--box-shadow); \r\n  max-width: 78rem;\r\n  margin-left: 3rem;\r\n  padding: 1rem 1rem 1rem 0;\r\n  background-color: var(--ligth-black);\r\n}\r\n\r\n.btn-fitness {\r\n  position: relative;\r\n  margin-left: 31rem;\r\n  margin-bottom: 1rem;\r\n  padding: 1rem 2rem;\r\n  font-size: 2rem;\r\n  font-weight: 700;\r\n  color: var(--text-color);\r\n  border-radius: .5rem;\r\n  cursor: pointer;\r\n  background-color:  rgba(4, 14, 152, 0.947);\r\n  z-index: 1;\r\n}\r\n\r\n.btn-fitness:hover {\r\n  box-shadow: 0 .3rem .8rem yellow;\r\n}\r\n\r\n@media screen and (max-width: 1040px) {\r\n\r\n  ul.build img {\r\n    margin-left: -16rem;\r\n  }\r\n\r\n  ul.grow img.lower {\r\n\r\n    margin-right: -28rem;\r\n}\r\n\r\nul.grow img.grow {\r\n  margin-right: 26rem;\r\n\r\n}\r\n\r\n\r\n}\r\n\r\n@media screen and (max-width: 897px) {\r\n\r\n  ul.strong img {\r\n    margin-right: 0;\r\n  }\r\n\r\n  ul.build img {\r\n    margin-left: -15rem;\r\n  }\r\n\r\n  ul.grow img.lower {\r\n    padding-left: 18rem;\r\n  }\r\n}\r\n\r\n@media screen and (max-width: 674px) {\r\n  ul.strong img {\r\n    margin-left: 4rem;\r\n  }\r\n\r\n  ul.fit img {\r