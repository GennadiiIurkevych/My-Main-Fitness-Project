{"mappings":"AACA;;;;;;;;;;;;;;AAcA;;;;;AAKA;;;;;;;;;;AASA;;;;;;;;AAQA;;;;;;;;AAQA;;;;;;AAMA;;;;;AAKA;;;;;;;;;AASA;;;;;AAKA;;;;;;;;AAUA;;;;;;AAOA;;;;;;;;;;;AAWA;;;;AAIA;EAEE;;;;EAIA;;;;;;;;;;;;;EAaA;;;;;;;;;;;;;EAaA;;;;EAIA;;;;;;;;;EASA;;;;;;;;EAQA;;;;;AAMF;EAEE;;;;;;EAMA;;;;;;EAMA;;;;;;;AAQF;;;;ACtLA;;;;;;;;;;;AAWA;;;;AAQA;;;;AAIA;;;;;;;;;;;;AAYA;;;;;;;AAOA;;;;;;;;AAQA;;;;;;AAMA;;;;;;AAOA;;;;;;;AAQA;;;;;;;;;;AAUA;;;;AAIA;;;;;;ACpFA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiHA;;;;;AAQA;;;;AAaA;;;;;;;;;;AAeA;;;;;AASA;;;;;;AAQA;;;;AAMA;;;;;AAYA;;;;;AAOA;;;;AAUA;;;;;;;AAYA;;;;AAMA;;;;;;;AAOA;;;;AAGA;;;;AAQA;;;;;;AAUA;;;;;;;;;;;;;AAmBA;;;;AAQA;;;;;;AAWA;;;;AAMA;;;;AAMA;;;;AAMA;;;;AAAA;;;;AAQA;;;;;AAOA;;;;AAOA;;;;;AAOA;;;;AAMA;;;;AAeA;;;;;AAIA;;;;AAGA;;;;;;AAUA;;;;AAMA;;;;AAOA;;;;;AAQA;;;;AAOA;;;;AAQA;;;;;AAcA;;;;;AAMA;;;;AAGA;;;;;AAIA;;;;;AAIA;;;;AAGA;;;;;;;;;;;;AAWA","sources":["src/header/header.css","src/home/home.css","src/input.css"],"sourcesContent":["\r\n.nav-img {\r\n  display: flex;\r\n  position: absolute;\r\n  width: 90px;\r\n  height: 90px;\r\n  border: .2rem solid;\r\n  border-color: rgb(245 158 11 / var(--tw-border-opacity, 1));\r\n  border-radius: 50%;\r\n  margin-top: .75rem;\r\n  margin-left: 1.25rem;\r\n  z-index: 1; \r\n  transition: .8s;\r\n}\r\n\r\n.nav-img:hover {\r\n  transform: scale(1.15);\r\n  animation: spin 1s linear 1; \r\n}\r\n\r\n@keyframes spin {\r\nfrom {\r\n  transform: rotate(0);\r\n}\r\nto {\r\n    transform: rotateY(360deg);\r\n  }\r\n}\r\n\r\n.header {\r\n  display: flex;\r\n  width: 100%;\r\n  top: 0;\r\n  left: 0;\r\n  background-color: var(--black);\r\n}\r\n\r\n.nav-logo {\r\n  width: 600px !important;\r\n  text-align: center;\r\n  font-size: var(--medium-fz);\r\n  color: var(--main-color);\r\n  margin-left: 3rem;\r\n}\r\n\r\n.logo-name {\r\n  font-weight: 700;\r\n  font-size: 2.5rem;\r\n  padding-top: 1rem;\r\n}\r\n \r\nnav a {\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.nav {\r\n  width: 1366px;\r\n  position: relative;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: .5rem 5%;\r\n}\r\n\r\n.nav-menu {\r\n  display: flex;\r\n  gap: 1rem;\r\n}\r\n\r\n.nav-close, \r\n.nav-toggle {\r\n  display: flex;\r\n  align-items: center;\r\n  font-size: 2.5rem;\r\n  color: var(--text-color);\r\n  cursor: pointer;\r\n  display: none;\r\n}\r\n\r\n.nav-menu .nav-link {\r\n\r\n  font-size: 14px !important;\r\n  position: relative;\r\n  color: var(--text-color);\r\n}\r\n\r\n.nav-menu .nav-link::after {\r\n  content: '';\r\n  position: absolute;\r\n  left: 0;\r\n  bottom: -0.3rem;\r\n  width: 0;\r\n  height: 2px;\r\n  background-color: var(--main-color);\r\n  transition: all .3s;\r\n}\r\n\r\n.nav-menu .nav-link:hover::after {\r\n  width: 100%;\r\n}\r\n\r\n@media screen and (max-width: 897px) {\r\n\r\n  .wrapper {\r\n    width: 900px;\r\n  }\r\n\r\n  .nav-menu {\r\n    position: fixed;\r\n    top: -100%;\r\n    left: 0;\r\n    width: 100%;\r\n    background-color: #111;\r\n    padding: 1.5rem .5rem;\r\n    box-shadow: var(--box-shadow);\r\n    text-align: center;\r\n    display: flex;\r\n    flex-direction: column;\r\n  }\r\n \r\n  .nav-close {\r\n    position: absolute;\r\n    top: 1.5rem;\r\n    right: 2.5rem;\r\n    width: 2.5rem;\r\n    height: 2.5rem;\r\n    border-radius: 50%;\r\n    box-shadow: var(--box-shadow);\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n  }\r\n\r\n  .nav-close:hover {\r\n    transform: rotate(90deg);\r\n  }\r\n\r\n  .nav-toggle {\r\n    width: 2.5rem;\r\n    height: 2.5rem;\r\n    box-shadow: var(--box-shadow);\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n  }\r\n\r\n  .nav-logo {\r\n    display: flex;\r\n    width: 680px !important;\r\n    text-align: center;\r\n    font-size: var(--medium-fz);\r\n    color: var(--main-color);\r\n  }\r\n\r\n  .nav {\r\n    margin-left: 2rem;\r\n  }\r\n\r\n}\r\n\r\n@media screen and (max-width: 420px) {\r\n\r\n  .nav-logo {\r\n    width: 280px;\r\n    font-size: var(--small-fz) !important;\r\n    line-height: 1.25rem !important;\r\n  }\r\n\r\n  .nav-img {\r\n    width: 60px;\r\n    height: 60px;\r\n    margin-top: 1rem;\r\n  }\r\n\r\n  .logo-name {\r\n    font-weight: 500;\r\n    font-size: 1.5rem;\r\n    line-height: 1.5rem;\r\n  }\r\n\r\n}\r\n\r\n.show-menu {\r\n  top: 0;\r\n}","\r\n.home-section {\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  flex-wrap: wrap;\r\n  gap: 2rem;\r\n  padding-top: 2rem 3rem;\r\n  max-width: var(--max-width);\r\n  margin: 0 auto;\r\n}\r\n\r\n.home-section .home-content {\r\n  flex: 1 1 40rem;\r\n}\r\n\r\n.home-content .home-img {\r\n  flex: 1 1 40rem;\r\n}\r\n\r\n.home-content {\r\n  margin-left: 3rem;\r\n}\r\n\r\n.home-section::before {\r\n  content: 'FITNESS';\r\n  position: absolute;\r\n  top: 3rem;\r\n  right: 20rem;\r\n  line-height: 7rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n  opacity: 0.05;\r\n  font-size: 15rem;\r\n}\r\n\r\n.home-content h4 {\r\n  margin-bottom: 1rem; \r\n  font-size: 2.5rem;\r\n  font-weight: 800;\r\n  color: var(--text-color);\r\n}\r\n\r\n.home-content h2 {\r\n  margin-bottom: 1rem;\r\n  font-size: var(--big-fz);\r\n  font-weight: 800;\r\n  line-height: 6rem;\r\n  color: var(--text-color);\r\n}\r\n\r\n.home-content h2 span {\r\n  -webkit-text-fill-color:  var(--black);;\r\n  -webkit-text-stroke: 1px var(--main-color);\r\n  font-size: var(--big-fz);\r\n}\r\n\r\n.home-content p {\r\n  margin-bottom: 2rem;\r\n\r\n  color: var(--text-color);\r\n  font-size: 1.6rem;\r\n}\r\n\r\n.home-img {\r\n\r\n  width: 500px;\r\n  height: 650px;\r\n  margin-right: 2.5rem;\r\n  z-index: 1;\r\n}\r\n\r\n.btn {\r\n  display: inline-block;\r\n  padding: 1rem 2rem;\r\n  font-size: 1.5rem;\r\n  color: var(--text-color);\r\n  background-color: var(--main-color);\r\n  border-radius: .5rem;\r\n  cursor: pointer;\r\n}\r\n\r\n.btn:hover {\r\n  box-shadow: 0 .3rem 1rem var(--main-color);\r\n}\r\n\r\n.bg-blur {\r\n  position: absolute;\r\n  box-shadow: 0 0 100rem 8rem var(--main-color);\r\n  z-index: -1;\r\n}","@import url(./header/header.css);\r\n@import url(./home/home.css);\r\n\r\n\r\n@tailwind base;\r\n@tailwind components;\r\n@tailwind utilities;\r\n\r\n.wrapper {\r\n  width: 1366px;\r\n}\r\n\r\n:root {\r\n  --main-color: rgb(247, 160, 10);\r\n  --black: #181818;\r\n  --ligth-black: #383838;\r\n  --text-color: #ffff;\r\n  --max-width: 120rem;\r\n  --box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .7);\r\n  --big-fz: calc(20px + (50 - 30) * ((100vw - 300px) / (1300 - 300)));\r\n  --medium-fz: calc(18px + (20 - 18) * ((100vw - 300px) / (1300 - 300)));\r\n  --small-fz: calc(15px + (18 - 15) * ((100vw - 300px) / (1300 - 300)));\r\n}\r\n\r\nbody {\r\n  background-color: rgb(38 38 38 / var(--tw-bg-opacity, 1));\r\n}"],"names":[],"version":3,"file":"index.812b439a.css.map","sourceRoot":"/__parcel_source_root/"}